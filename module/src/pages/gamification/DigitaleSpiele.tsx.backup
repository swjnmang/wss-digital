                                    newA[3] = Math.min(5, Math.max(0, parseInt(e.target.value) || 0))
                                    setBeurteilungData({...beurteilungData, partA: newA})
                                  }}
                                  className="w-full border border-slate-300 rounded p-1"
                                />
                              </td>
