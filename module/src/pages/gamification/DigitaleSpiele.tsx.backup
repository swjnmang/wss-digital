  { id: 29, question: 'Was ist "Scripted Game Flow"?', options: ['Der Spielverlauf folgt einer vorgegebenen Reihenfolge', 'Spieler schreiben die Geschichte', 'Spontane Spielweise', 'Improvisation'], correctAnswer: 0 },
