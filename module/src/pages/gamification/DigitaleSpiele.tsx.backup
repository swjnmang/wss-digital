  { id: 58, question: 'Welche Mechanik beschreibt "Positional Play"?', options: ['Die Position ist strategisch wichtig', 'Position', 'Platzierung', 'Standort'], correctAnswer: 0 },
  { id: 59, question: 'Was ist "Abstract Game"?', options: ['Spiel ohne Thema, reines Strategie-Spiel', 'Abstrakte Kunst', 'Abstraktes Denken', 'Theoretisches Spiel'], correctAnswer: 0 },
  { id: 60, question: 'Welche Mechanik kombiniert mehrere Spielelemente?', options: ['Hybrid Mechanics', 'Kombinierte Mechaniken', 'Gemischte Regeln', 'A und B'], correctAnswer: 3 },
]

export default function DigitaleSpiele() {
  const [activeTab, setActiveTab] = useState<'aufgaben' | 'kostenlose' | 'uebungen'>('aufgaben')
  const [expandedTasks, setExpandedTasks] = useState<Record<number, boolean>>({})
  const [quizStarted, setQuizStarted] = useState(false)
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0)
  const [selectedAnswer, setSelectedAnswer] = useState<number | null>(null)
  const [answered, setAnswered] = useState(false)
  const [score, setScore] = useState(0)
  const [correctAnswers, setCorrectAnswers] = useState<number[]>([])
  const [quizQuestions, setQuizQuestions] = useState<QuizQuestion[]>([])
  const [genreTable, setGenreTable] = useState<Record<string, { description: string; examples: string }>>({
    action: { description: '', examples: '' },
    shooter: { description: '', examples: '' },
    adventure: { description: '', examples: '' },
    beatEmUps: { description: '', examples: '' },
    jumpRun: { description: '', examples: '' },
    openWorld: { description: '', examples: '' },
    rpg: { description: '', examples: '' },
    simulation: { description: '', examples: '' },
    strategy: { description: '', examples: '' },
    sports: { description: '', examples: '' },
    indie: { description: '', examples: '' },
    serious: { description: '', examples: '' },
  })

  // Beurteilungsbogen State
  const [beurteilungData, setBeurteilungData] = useState({
    schuelerName: '',
    klasse: '',
    spielName: '',
    format: '',
    partA: [0, 0, 0, 0, 0],
    partB: [0, 0, 0, 0, 0],
    anmerkungen: '',
  })

  // ===== EXERCISE STATES =====
  const [exercise1Items, setExercise1Items] = useState([
    { id: 1, element: 'Punkte (XP, Score)', correctCategories: ['Motivationssysteme'], placedIn: null as string | null, hasError: false },
    { id: 2, element: 'Achievements/Trophäen', correctCategories: ['Motivationssysteme'], placedIn: null, hasError: false },
    { id: 3, element: 'Loot/Belohnungskisten', correctCategories: ['Motivationssysteme', 'Spielmechaniken'], placedIn: null, hasError: false },
    { id: 4, element: 'Jump & Walk Mechanik', correctCategories: ['Spielmechaniken'], placedIn: null, hasError: false },
    { id: 5, element: 'Leaderboards', correctCategories: ['Motivationssysteme'], placedIn: null, hasError: false },
    { id: 6, element: 'Sound-Feedback', correctCategories: ['Feedback-Systeme'], placedIn: null, hasError: false },
    { id: 7, element: 'Levelsystem', correctCategories: ['Motivationssysteme'], placedIn: null, hasError: false },
    { id: 8, element: 'Real-time Kontrolle', correctCategories: ['Spielmechaniken'], placedIn: null, hasError: false },
    { id: 9, element: 'Visuelle Effekte (Partikeln)', correctCategories: ['Feedback-Systeme'], placedIn: null, hasError: false },
    { id: 10, element: 'Haptic Feedback (Vibration)', correctCategories: ['Feedback-Systeme'], placedIn: null, hasError: false },
    { id: 11, element: 'Boss-Kämpfe', correctCategories: ['Spielmechaniken'], placedIn: null, hasError: false },
    { id: 12, element: 'In-Game Währung', correctCategories: ['Motivationssysteme'], placedIn: null, hasError: false },
    { id: 13, element: 'Musik/Soundtrack', correctCategories: ['Feedback-Systeme'], placedIn: null, hasError: false },
    { id: 14, element: 'Progression Bar', correctCategories: ['Motivationssysteme'], placedIn: null, hasError: false },
    { id: 15, element: 'Inventar-System', correctCategories: ['Spielmechaniken'], placedIn: null, hasError: false },
    { id: 16, element: 'Tutorial/Onboarding', correctCategories: ['Spielmechaniken'], placedIn: null, hasError: false },
  ])
  const [exercise1SituationIndex, setExercise1SituationIndex] = useState(0)
  const [exercise1SituationAnswers, setExercise1SituationAnswers] = useState<(string | null)[]>([])
  const [exercise1ShowPhaseDecision, setExercise1ShowPhaseDecision] = useState(false)
  const [exercise1Phase2ShowFeedback, setExercise1Phase2ShowFeedback] = useState(false)
  const [exercise1Phase2FeedbackIsCorrect, setExercise1Phase2FeedbackIsCorrect] = useState(false)
  const [exercise2Current, setExercise2Current] = useState(0)
  const [exercise2Answers, setExercise2Answers] = useState<number[]>([])
  const [exercise2ShowResult, setExercise2ShowResult] = useState(false)
  const [exercise3Items, setExercise3Items] = useState<Array<{id: number; text: string; correctCategory: 'chancen' | 'risiken'; placedIn: 'chancen' | 'risiken' | null; hasError: boolean}>>([
    { id: 1, text: 'Verbessert Strategisches Denken', correctCategory: 'chancen', placedIn: null, hasError: false },
    { id: 2, text: 'Fördert Kreativität und Problemlösung', correctCategory: 'chancen', placedIn: null, hasError: false },
    { id: 3, text: 'Risiko der Spielsucht', correctCategory: 'risiken', placedIn: null, hasError: false },
    { id: 4, text: 'Schulung motorischer Fähigkeiten', correctCategory: 'chancen', placedIn: null, hasError: false },
    { id: 5, text: 'Soziale Isolation möglich', correctCategory: 'risiken', placedIn: null, hasError: false },
    { id: 6, text: 'Förderung von Teamfähigkeit (Multiplayer)', correctCategory: 'chancen', placedIn: null, hasError: false },
    { id: 7, text: 'Finanzielle Gefahren durch In-Game-Käufe', correctCategory: 'risiken', placedIn: null, hasError: false },
    { id: 8, text: 'Verbessert Hand-Auge-Koordination', correctCategory: 'chancen', placedIn: null, hasError: false },
    { id: 9, text: 'Psychische Belastung durch Gewalt-Inhalte', correctCategory: 'risiken', placedIn: null, hasError: false },
    { id: 10, text: 'Vermittlung von Lernstoff spielerisch', correctCategory: 'chancen', placedIn: null, hasError: false },
  ])
  const [exercise3Score, setExercise3Score] = useState(0)
  
  // Exercise 4: Bergen Gaming Addiction Scale
  const [exercise4Answers, setExercise4Answers] = useState<number[]>([0, 0, 0, 0, 0, 0, 0])
  const [exercise4ShowResult, setExercise4ShowResult] = useState(false)
  
  // Exercise 5: Internet Gaming Addiction Test (IGAT)
  const [exercise5Answers, setExercise5Answers] = useState<number[]>(Array(20).fill(0))
  const [exercise5ShowResult, setExercise5ShowResult] = useState(false)
  
  const exercise5Questions = [
    'Ich denke an das Spielen, auch wenn ich gerade nicht spielen kann.',
    'Ich habe Angst oder werde unruhig, wenn ich nicht spielen kann.',
    'Ich muss immer länger spielen, um mich befriedigt zu fühlen.',
    'Ich habe versucht, weniger zu spielen, bin aber gescheitert.',
    'Meine Gedanken werden von Spielen dominiert.',
    'Wenn ich nicht spielen kann, fühle ich mich deprimiert.',
    'Ich spiele immer länger, um den gleichen Nervenkitzel zu bekommen.',
    'Ich lüge Eltern, Lehrer oder Freunden über mein Spielverhalten.',
    'Ich spiele, um Probleme oder negative Gefühle zu vergessen.',
    'Ich habe wichtige schulische oder soziale Aktivitäten vernachlässigt, um zu spielen.',
    'Menschen in meinem Leben haben sich über mein Spielverhalten beschwert.',
    'Ich spiele, um mich besser zu fühlen, wenn ich traurig bin.',
    'Ich bin nicht in der Lage, mein Spielverhalten zu kontrollieren.',
    'Ich vernachlässige meine Schlafzeit, um mehr zu spielen.',
    'Ich spiele weitermachen, obwohl es mir Probleme bereitet.',
    'Ich kann nicht aufhören zu spielen, obwohl ich es versucht habe.',
    'Ich vernachlässige Freunde oder Familie, um zu spielen.',
    'Ich habe körperliche Beschwerden bekommen von zu viel Spielen (Kopfschmerzen, Rückenschmerzen, etc.).',
    'Ich brauche stärkere oder längere Spielsitzungen, um die gleiche Aufregung zu bekommen.',
    'Ich spiele trotz der negativen Konsequenzen weiter.',
  ]
  
  const handleExercise5Answer = (questionIndex: number, value: number) => {
    const updated = [...exercise5Answers]
    updated[questionIndex] = value
    setExercise5Answers(updated)
  }
  
  const calculateExercise5Score = () => {
    const totalScore = exercise5Answers.reduce((sum, answer) => sum + answer, 0)
    setExercise5ShowResult(true)
    return totalScore
  }
  
  const resetExercise5 = () => {
    setExercise5Answers(Array(20).fill(0))
    setExercise5ShowResult(false)
  }
  
  const getExercise5Interpretation = (score: number) => {
    if (score <= 20) {
      return {
        level: 'Kein problematisches Spielverhalten',
        color: 'green',
        icon: '✅',
        description: 'Dein Internet-Spielverhalten ist gesund und angemessen.'
      }
    } else if (score <= 40) {
      return {
        level: 'Leichtes Risiko',
        color: 'yellow',
        icon: '⚠️',
        description: 'Du zeigst erste Anzeichen problematischen Spielverhaltens. Achte auf deine Spielzeit.'
      }
    } else if (score <= 60) {
      return {
        level: 'Moderates Risiko',
        color: 'orange',
        icon: '⚠️⚠️',
        description: 'Dein Spielverhalten könnte süchtig sein. Setze klare Limits und suche Unterstützung.'
      }
    } else {
      return {
        level: 'Hohes Suchtrisiko - Wahrscheinliche Internet Gaming Disorder',
        color: 'red',
        icon: '🚨',
        description: 'Du zeigst starke Anzeichen von Spielsucht. Bitte suche professionelle Hilfe auf.'
      }
    }
  }
  
  // State für expandable Exercises
  const [expandedExercises, setExpandedExercises] = useState<Record<number, boolean>>({})
  
  const exercise4Questions = [
    { id: 1, question: 'Meine Gedanken werden von Spielen dominiert, auch wenn ich gerade nicht spielen kann.' },
    { id: 2, question: 'Wenn ich nicht spielen kann, fühle ich mich ruhelos, reizbar und oder traurig.' },
    { id: 3, question: 'Ich muss immer länger spielen, um die gleiche Aufregung und Befriedigung zu bekommen.' },
    { id: 4, question: 'Ich habe mehrfach versucht, mein Spielverhalten einzuschränken oder zu kontrollieren, bin aber gescheitert.' },
    { id: 5, question: 'Ich spiele, um so bald wie möglich meine Probleme oder meine schlechte Laune zu vergessen.' },
    { id: 6, question: 'Ich lüge meinen Familie oder meine Freunde über meine Spielzeit und wie viel Zeit ich damit verbracht habe.' },
    { id: 7, question: 'Ich habe bedeutende Beziehungen, Schulleistungen oder berufliche Chancen aufs Spiel gesetzt oder verloren wegen des Spielens.' },
  ]
  
  const handleExercise4Answer = (questionIndex: number, value: number) => {
    const updated = [...exercise4Answers]
    updated[questionIndex] = value
    setExercise4Answers(updated)
  }
  
  const calculateExercise4Score = () => {
    const totalScore = exercise4Answers.reduce((sum, answer) => sum + answer, 0)
    setExercise4ShowResult(true)
    return totalScore
  }
  
  const resetExercise4 = () => {
    setExercise4Answers([0, 0, 0, 0, 0, 0, 0])
    setExercise4ShowResult(false)
  }
  
  const getExercise4Interpretation = (score: number) => {
    if (score <= 7) {
      return {
        level: 'Kein problematisches Spielverhalten',
        color: 'green',
        icon: '✅',
        description: 'Dein Spielverhalten ist gesund und angemessen. Du hast eine gute Balance zwischen Spielen und anderen Aktivitäten.'
      }
    } else if (score <= 13) {
      return {
        level: 'Leichtes Risiko',
        color: 'yellow',
        icon: '⚠️',
        description: 'Du solltest auf dein Spielverhalten achten. Es gibt erste Anzeichen, dass das Spielen zu viel Raum in deinem Leben einnimmt.'
      }
    } else if (score <= 20) {
      return {
        level: 'Moderates Risiko',
        color: 'orange',
        icon: '⚠️⚠️',
        description: 'Dein Spielverhalten könnte problematisch werden. Versuche, klare Grenzen zu setzen und deine Spielzeit zu reduzieren.'
      }
    } else {
      return {
        level: 'Hohes Suchtrisiko',
        color: 'red',
        icon: '🚨',
        description: 'Dein Spielverhalten deutet auf mögliche Spielsucht hin. Suche das Gespräch mit Eltern, Lehrern oder professionellen Hilfeanbietern.'
      }
    }
  }

  const toggleTask = (taskId: number) => {
    setExpandedTasks(prev => ({ ...prev, [taskId]: !prev[taskId] }))
  }

  const toggleExercise = (exerciseId: number) => {
    setExpandedExercises(prev => ({ ...prev, [exerciseId]: !prev[exerciseId] }))
  }

  const startQuiz = () => {
    const shuffled = [...QUIZ_POOL].sort(() => Math.random() - 0.5)
    const selected = shuffled.slice(0, 15)
    setQuizQuestions(selected)
    setQuizStarted(true)
    setCurrentQuestionIndex(0)
    setSelectedAnswer(null)
    setAnswered(false)
    setScore(0)
    setCorrectAnswers([])
  }

  const handleAnswerSelect = (answerIndex: number) => {
    if (!answered) {
      setSelectedAnswer(answerIndex)
      setAnswered(true)
      const isCorrect = answerIndex === quizQuestions[currentQuestionIndex].correctAnswer
      if (isCorrect) {
        setScore(score + 1)
        setCorrectAnswers([...correctAnswers, quizQuestions[currentQuestionIndex].id])
      }
    }
  }

  const nextQuestion = () => {
    if (currentQuestionIndex < quizQuestions.length - 1) {
      setCurrentQuestionIndex(currentQuestionIndex + 1)
      setSelectedAnswer(null)
      setAnswered(false)
    } else {
      const percentage = (score / quizQuestions.length) * 100
      if (percentage >= 75) {
        downloadQuizResult(true, score)
      } else {
        alert(`Nicht bestanden! Du hast ${score} von 15 Fragen richtig (${percentage.toFixed(1)}%). Du brauchst 75% (11-12 Fragen).`)
        startQuiz()
      }
    }
  }

  const downloadQuizResult = (passed: boolean, finalScore: number) => {
    const pdf = new jsPDF()
    let yPosition = 15

    pdf.setFontSize(18)
    pdf.setFont('Helvetica', 'bold')
    pdf.setTextColor(0, 0, 0)
    pdf.text('Arbeitsauftrag 1: Fachbegriffe-Check', 15, yPosition)
    yPosition += 12

    pdf.setFontSize(14)
    pdf.setFont('Helvetica', 'bold')
    if (passed) {
      pdf.setTextColor(34, 197, 94)
      pdf.text('✓ BESTANDEN', 15, yPosition)
    } else {
      pdf.setTextColor(239, 68, 68)
      pdf.text('✗ NICHT BESTANDEN', 15, yPosition)
    }
    pdf.setTextColor(0, 0, 0)
    yPosition += 12

    pdf.setFontSize(11)
    pdf.setFont('Helvetica', 'normal')
    pdf.text(`Datum: ${new Date().toLocaleDateString('de-DE')}`, 15, yPosition)
    yPosition += 6
    pdf.text(`Richtige Antworten: ${finalScore}/15`, 15, yPosition)
    yPosition += 6
    const percentage = (finalScore / 15) * 100
    pdf.text(`Prozentsatz: ${percentage.toFixed(1)}%`, 15, yPosition)
    yPosition += 6
    pdf.text(`Erforderlich: 75% (11-12 Fragen)`, 15, yPosition)
    yPosition += 12

    pdf.setFontSize(10)
    pdf.setFont('Helvetica', 'bold')
    pdf.text('Beantwortete Fragen:', 15, yPosition)
    yPosition += 8

    pdf.setFont('Helvetica', 'normal')
    pdf.setFontSize(9)
    quizQuestions.forEach((q, idx) => {
      const isCorrect = correctAnswers.includes(q.id)
      if (isCorrect) {
        pdf.setTextColor(34, 197, 94)
        pdf.text(`✓ ${idx + 1}. ${q.question.substring(0, 50)}...`, 15, yPosition)
      } else {
        pdf.setTextColor(239, 68, 68)
        pdf.text(`✗ ${idx + 1}. ${q.question.substring(0, 50)}...`, 15, yPosition)
      }
      pdf.setTextColor(0, 0, 0)
      yPosition += 5

      if (yPosition > 270) {
        pdf.addPage()
        yPosition = 15
      }
    })

    yPosition += 5
    pdf.setFontSize(8)
    pdf.setFont('Helvetica', 'italic')
    pdf.text('Diese Bestätigung wurde am ' + new Date().toLocaleString('de-DE') + ' automatisch generiert.', 15, yPosition)

    pdf.save(`Fachbegriffe-Check-Ergebnis-${new Date().getTime()}.pdf`)
  }

  const handleGenreChange = (genre: string, field: 'description' | 'examples', value: string) => {
    setGenreTable(prev => ({
      ...prev,
      [genre]: { ...prev[genre], [field]: value }
    }))
  }

  const downloadGenreTable = () => {
    const pdf = new jsPDF()
    let yPosition = 15

    pdf.setFontSize(16)
    pdf.setFont('Helvetica', 'bold')
    pdf.text('Mission: Genre-Detektiv', 15, yPosition)
    yPosition += 12

    pdf.setFontSize(11)
    pdf.setFont('Helvetica', 'normal')
    pdf.text('Ausgefüllt von: ____________________', 15, yPosition)
    yPosition += 8
    pdf.text('Datum: ____________________', 15, yPosition)
    yPosition += 12

    pdf.setFontSize(10)
    const col1Width = 35
    const col2Width = 60
    const col3Width = 60

    const genres = [
      { key: 'action', label: 'Action' },
      { key: 'shooter', label: 'Shooter' },
      { key: 'adventure', label: 'Adventure' },
      { key: 'beatEmUps', label: 'Beat \'em ups' },
      { key: 'jumpRun', label: 'Jump \'n\' Run' },
      { key: 'openWorld', label: 'Open World' },
      { key: 'rpg', label: 'Rollenspiele/RPG' },
      { key: 'simulation', label: 'Simulationen' },
      { key: 'strategy', label: 'Aufbau- und Strategiespiele' },
      { key: 'sports', label: 'Sportspiele' },
      { key: 'indie', label: 'Indie-Games' },
      { key: 'serious', label: 'Serious Games' },
    ]

    pdf.setFillColor(200, 200, 200)
    pdf.setFont('Helvetica', 'bold')
    pdf.rect(15, yPosition - 5, col1Width, 8, 'F')
    pdf.rect(15 + col1Width, yPosition - 5, col2Width, 8, 'F')
    pdf.rect(15 + col1Width + col2Width, yPosition - 5, col3Width, 8, 'F')

    pdf.text('Genre', 17, yPosition)
    pdf.text('Beschreibung', 15 + col1Width + 2, yPosition)
    pdf.text('Beispiele', 15 + col1Width + col2Width + 2, yPosition)
    yPosition += 10

    pdf.setFont('Helvetica', 'normal')
    pdf.setFontSize(9)

    genres.forEach((genre) => {
      const desc = genreTable[genre.key]?.description || ''
      const ex = genreTable[genre.key]?.examples || ''

      const descLines = pdf.splitTextToSize(desc, col2Width - 4)
      const exLines = pdf.splitTextToSize(ex, col3Width - 4)
      const rowHeight = Math.max(6, descLines.length * 4, exLines.length * 4) + 2

      if (yPosition + rowHeight > 270) {
        pdf.addPage()
        yPosition = 15
      }

      pdf.rect(15, yPosition, col1Width, rowHeight)
      pdf.text(genre.label, 17, yPosition + 3)

      pdf.rect(15 + col1Width, yPosition, col2Width, rowHeight)
      pdf.text(descLines, 15 + col1Width + 2, yPosition + 3)

      pdf.rect(15 + col1Width + col2Width, yPosition, col3Width, rowHeight)
      pdf.text(exLines, 15 + col1Width + col2Width + 2, yPosition + 3)

      yPosition += rowHeight
    })

    pdf.save(`Genre-Detektiv-Tabelle.pdf`)
  }

  // Beurteilungsbogen Berechnungsfunktionen
  const calculateBeurteilung = () => {
    const sumA = beurteilungData.partA.reduce((a, b) => a + b, 0)
    const sumB = beurteilungData.partB.reduce((a, b) => a + b, 0)
    const total = sumA + sumB
    
    // Maximalwerte je nach Format
    const isPodcast = beurteilungData.format === 'Podcast'
    const maxB = isPodcast ? 8 : 10
    const maxPoints = isPodcast ? 43 : 45
    
    const percentage = (total / maxPoints) * 100

    // Note nach deutschem Notensystem
    let note = 6
    if (percentage >= 96) note = 1
    else if (percentage >= 85) note = 2
    else if (percentage >= 70) note = 3
    else if (percentage >= 55) note = 4
    else if (percentage >= 40) note = 5

    return { sumA, sumB, total, maxB, maxPoints, percentage: percentage.toFixed(1), note }
  }

  const printBeurteilung = () => {
    const element = document.getElementById('beurteilungsbogen-print')
    if (!element) return

    const printWindow = window.open('', '_blank')
    if (!printWindow) return

    printWindow.document.write(`
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="UTF-8">
        <title>Beurteilungsbogen: Spielerezension</title>
        <style>
          * { margin: 0; padding: 0; box-sizing: border-box; }
          html { height: 100%; }
          body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
            padding: 40px;
            background: white;
            color: #000;
            line-height: 1.4;
          }
          h4, h5 { margin: 12px 0 8px 0; page-break-inside: avoid; }
          h4 { font-size: 1.1em; }
          h5 { font-size: 0.95em; }
          div { page-break-inside: avoid; }
          table {
            width: 100%;
            border-collapse: collapse;
            margin: 8px 0;
            page-break-inside: avoid;
          }
          td, th {
            border: 1px solid #999;
            padding: 6px;
            text-align: left;
            font-size: 0.9em;
          }
          th { background-color: #ddd; font-weight: bold; }
          tr.bg-blue-200 { background-color: #bfdbfe; }
          tr.bg-blue-100 { background-color: #dbeafe; }
          tr.bg-green-200 { background-color: #bbf7d0; }
          tr.bg-green-100 { background-color: #dcfce7; }
          tr.bg-slate-50 { background-color: #f8fafc; }
          tr.bg-slate-100 { background-color: #f1f5f9; }
          input { border: 1px solid #999; padding: 2px 4px; font-size: 0.9em; }
          textarea { border: 1px solid #999; padding: 4px; font-size: 0.9em; }
          .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin: 8px 0;
          }
          .border-2 { border: 2px solid #999; }
          .rounded-lg { border-radius: 4px; }
          .p-6 { padding: 12px; }
          input[type="text"], input[type="number"], select {
            width: 100%;
            padding: 4px;
            margin: 2px 0;
          }
          .text-xs { font-size: 0.75em; }
          .italic { font-style: italic; }
          .text-slate-600 { color: #475569; }
          ul { margin-left: 20px; }
          @page {
            size: A4;
            margin: 20mm;
          }
          @media print {
            body { padding: 0; }
            * { page-break-inside: avoid; }
          }
        </style>
      </head>
      <body>
        ${element.innerHTML}
      </body>
      </html>
    `)
    printWindow.document.close()
    setTimeout(() => {
      printWindow.print()
    }, 250)
  }

