                              </td>
                            </tr>
                            <tr className="bg-slate-50">
                              <td className="border border-slate-300 p-2">2. Audioqualität - Hintergrund</td>
                              <td className="border border-slate-300 p-2 text-center">2</td>
                              <td className="border border-slate-300 p-2">
                                <input
                                  type="number"
                                  min="0"
                                  max="2"
